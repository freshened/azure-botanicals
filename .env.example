# Required: Replace with your Stripe secret key (example: sk_test_... or sk_live_...).
STRIPE_SECRET_KEY=__REPLACE_WITH_STRIPE_SECRET_KEY__
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=__REPLACE_WITH_STRIPE_PUBLISHABLE_KEY__

# Connect: set STRIPE_USE_CONNECT=false to use your platform account only (no Connect platform setup).
# When true (default), STRIPE_CONNECTED_ACCOUNT_ID is required.
STRIPE_USE_CONNECT=true
STRIPE_CONNECTED_ACCOUNT_ID=acct_1234

# Optional: Public base URL used for Stripe onboarding and checkout redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Platform application fee in cents for direct charges.
STRIPE_CONNECT_APPLICATION_FEE_AMOUNT=123
STRIPE_PLATFORM_FEE_PERCENT=2
CHECKOUT_USE_PLATFORM_ONLY=false
STRIPE_WEBHOOK_SECRET=whsec___REPLACE_WITH_STRIPE_WEBHOOK_SIGNING_SECRET__
# Dev only: force redirect to /success even when Stripe returns a payment error.
NEXT_PUBLIC_CHECKOUT_FORCE_SUCCESS_REDIRECT=false

# SQLite (dev and production). Use a persistent path on the server so the file survives restarts.
# Dev:
DATABASE_URL=file:./prisma/dev.db
# Production example (single VPS / one container with a mounted volume):
# DATABASE_URL=file:/var/data/azure-botanicals/prod.db

# Portal sign-in (email OTP). Generate a long random string (32+ characters) for PORTAL_AUTH_SECRET.
PORTAL_AUTH_SECRET=__REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS__

# Purelymail / SMTP (portal sign-in emails)
# SSL/TLS option (recommended): smtp.purelymail.com:465 with SMTP_SECURE=true
# STARTTLS alternative: smtp.purelymail.com:587 with SMTP_SECURE=false
SMTP_HOST=smtp.purelymail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@yourdomain.com
SMTP_PASSWORD=__REPLACE_WITH_PURELYMAIL_PASSWORD_OR_APP_PASSWORD__
SMTP_FROM=you@yourdomain.com

# Optional: Vercel Blob read/write token (free tier exists; not required on a VPS). Without it, uploads go to storage/product-images and are served via /uploads/... (see app/uploads route + nginx).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional: comma-separated emails to upsert into the allowlist when you run: pnpm prisma db seed
# (You can also add or remove portal users in Admin → Settings → Portal users when signed in.)
# PORTAL_SEED_EMAILS=admin@example.com,other@example.com
